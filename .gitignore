# Deny by default — only track explicitly allowlisted files
*

# Allowlisted files
!.gitignore
!README.md
!CLAUDE.md
!CLAUDE_REFERENCE.md
!settings.json
!mcp.json.template
!plans/
!plans/**
# Ignore temporary/draft plans from worker agents
plans/label-autoconfirm-skew.md
!rules/
!rules/**
!hooks/
!hooks/**
!skills/
!skills/**
!mcp-servers/
!mcp-servers/**
# Ignore build artifacts and deps within mcp-servers
mcp-servers/**/node_modules/
mcp-servers/**/build/
!coordinator/
!coordinator/**
# Ignore build artifacts and deps within coordinator
coordinator/node_modules/
coordinator/build/
!CHEATSHEET.md
!COMPLETION_REPORT.md
