{
  "mcpServers": {
    "trello": {
      "command": "mcp-server-trello",
      "env": {
        "TRELLO_API_KEY": "<your-trello-api-key>",
        "TRELLO_TOKEN": "<your-trello-token>"
      }
    },
    "session-bus": {
      "command": "node",
      "args": ["<path-to-repo>/mcp-servers/session-bus/build/index.js"]
    },
    "tmux-control": {
      "command": "node",
      "args": ["<path-to-repo>/mcp-servers/tmux-control/build/index.js"]
    }
  }
}
